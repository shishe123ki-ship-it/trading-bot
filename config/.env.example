# Bybit API Credentials
# Erstelle Keys auf: https://testnet.bybit.com (Testnet) oder https://bybit.com (Live)
# Benötigt: Read + Trade Permissions für Derivatives/USDT Perpetual
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# true = Bybit Testnet (kein echtes Geld), false = Live-Trading
BYBIT_TESTNET=true

# Telegram Bot für Alerts und Steuerung
# Bot erstellen: https://t.me/BotFather → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token

# Deine Telegram User-ID (z.B. via @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id
